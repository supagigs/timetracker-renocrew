{
  "name": "time-tracker-new",
  "version": "1.0.0",
  "description": "Time tracking application to enable users to record work hours, monitor productivity, and analyze performance with accuracy.",
  "main": "main.js",
  "productName": "Time Tracker",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish=never",
    "pack": "electron-builder --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "time-tracker",
    "productivity",
    "electron",
    "supabase",
    "time-management"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.78.0",
    "canvas": "^3.2.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.552.0",
    "react-chartjs-2": "^5.3.1",
    "screenshot-desktop": "^1.15.2",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^38.3.0",
    "electron-builder": "^24.6.4",
    "to-ico": "^1.0.1"
  },
  "build": {
    "appId": "com.yourcompany.time-tracker",
    "productName": "Time Tracker",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
   
    "extraResources": [
      ".env"
    ],
    "asar": true,
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "SupagigsLogo.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "SupagigsLogo.png",
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Time Tracker"
    },
    "linux": {
      "target": "AppImage",
      "icon": "SupagigsLogo.png"
    }
  }
}
